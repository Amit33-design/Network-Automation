{# ═══════════════════════════════════════════════════════════
   Terraform Stack — GCP NCC Hub
   Template: gcp_ncc_stack.tf.j2
   Variables: org_name, stack_name, project, region, region_code,
              env, cidr, hub_cidr, cloud_router_asn
═══════════════════════════════════════════════════════════ #}
# ═══════════════════════════════════════════════════════════
# Stack   : {{ stack_name }}
# Region  : {{ region }}
# Project : {{ project }}
# Org     : {{ org_name }}
# Env     : {{ env }}
# Generated by NetDesign AI — multicloud use case
# ═══════════════════════════════════════════════════════════

terraform {
  required_version = ">= 1.6"
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 5.0"
    }
  }
  backend "gcs" {
    bucket = "{{ org_name | lower | replace(' ', '-') }}-tf-state"
    prefix = "network/{{ stack_name }}"
  }
}

provider "google" {
  project = "{{ project }}"
  region  = "{{ region }}"
}

locals {
  org_name         = "{{ org_name }}"
  stack_name       = "{{ stack_name }}"
  project          = "{{ project }}"
  region           = "{{ region }}"
  region_code      = "{{ region_code }}"
  env              = "{{ env }}"
  cidr             = "{{ cidr }}"
  hub_cidr         = "{{ hub_cidr }}"
  cloud_router_asn = {{ cloud_router_asn }}
}

# ── NCC Hub + Host VPC ────────────────────────────────────────
module "ncc" {
  source  = "../../../../modules/gcp-ncc-hub"
  version = "~> 2.0"

  org_name         = local.org_name
  project          = local.project
  region           = local.region
  env              = local.env
  cidr             = local.cidr
  hub_cidr         = local.hub_cidr
  cloud_router_asn = local.cloud_router_asn

  # Cloud NGFW
  enable_cloud_ngfw = true
  ngfw_tier         = "STANDARD"
  enable_cloud_nat  = true
}

# ── Cloud Interconnect VLAN attachments ──────────────────────
module "interconnect" {
  source = "../../../../modules/gcp-cloud-interconnect"

  project    = local.project
  region     = local.region
  router_id  = module.ncc.cloud_router_id
  vlan_cidr  = "169.254.20.0/29"
  peer_asn   = 65000
  bandwidth  = "BPS_10G"
  redundancy = "REDUNDANT"
}

# ── NCC Spoke Hub Connections ─────────────────────────────────
resource "google_network_connectivity_hub" "main" {
  name        = "${local.org_name}-ncc-hub-${local.region_code}"
  description = "NCC Hub for ${local.org_name} ${local.region}"
  project     = local.project
}

# ── Cloud NAT (for outbound from private subnets) ────────────
resource "google_compute_router_nat" "main" {
  name                               = "${local.org_name}-nat-${local.region_code}"
  router                             = module.ncc.cloud_router_name
  region                             = local.region
  project                            = local.project
  nat_ip_allocate_option             = "AUTO_ONLY"
  source_subnetwork_ip_ranges_to_nat = "ALL_SUBNETWORKS_ALL_IP_RANGES"

  log_config {
    enable = true
    filter = "ERRORS_ONLY"
  }
}

# ── Firewall rules (Cloud NGFW base) ─────────────────────────
resource "google_compute_firewall" "allow_iap" {
  name    = "${local.org_name}-allow-iap-${local.region_code}"
  network = module.ncc.host_vpc_id
  project = local.project

  allow {
    protocol = "tcp"
    ports    = ["22", "3389"]
  }
  source_ranges = ["35.235.240.0/20"]
  target_tags   = ["iap-access"]
  description   = "Allow IAP tunnel access"
}

resource "google_compute_firewall" "allow_internal" {
  name    = "${local.org_name}-allow-internal-${local.region_code}"
  network = module.ncc.host_vpc_id
  project = local.project

  allow {
    protocol = "all"
  }
  source_ranges = [local.cidr]
  description   = "Allow all internal traffic from org CIDR"
}

# ── Outputs ───────────────────────────────────────────────────
output "ncc_hub_id" {
  value       = module.ncc.hub_id
  description = "NCC Hub ID"
}

output "cloud_router_id" {
  value       = module.ncc.cloud_router_id
  description = "Cloud Router ID"
}

output "host_vpc_id" {
  value       = module.ncc.host_vpc_id
  description = "Host VPC ID"
}

output "interconnect_attachment_ids" {
  value       = module.interconnect.attachment_ids
  description = "Cloud Interconnect VLAN attachment IDs"
}

output "google_ncc_hub_id" {
  value       = google_network_connectivity_hub.main.id
  description = "Google NCC Hub resource ID"
}
