{# ═══════════════════════════════════════════════════════════
   Terraform Stack — Azure vWAN Hub
   Template: azure_vwan_stack.tf.j2
   Variables: org_name, stack_name, location, region_code, env,
              cidr, hub_cidr, er_asn, rg_name
═══════════════════════════════════════════════════════════ #}
# ═══════════════════════════════════════════════════════════
# Stack    : {{ stack_name }}
# Location : {{ location }}
# Org      : {{ org_name }}
# Env      : {{ env }}
# Generated by NetDesign AI — multicloud use case
# ═══════════════════════════════════════════════════════════

terraform {
  required_version = ">= 1.6"
  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 3.90"
    }
  }
  backend "azurerm" {
    resource_group_name  = "{{ rg_name }}-tfstate"
    storage_account_name = "{{ org_name | lower | replace(' ', '') | replace('-', '') | truncate(20, False, '') }}tfstate"
    container_name       = "tfstate"
    key                  = "network/{{ stack_name }}/terraform.tfstate"
  }
}

provider "azurerm" {
  features {}
}

locals {
  org_name    = "{{ org_name }}"
  stack_name  = "{{ stack_name }}"
  location    = "{{ location }}"
  region_code = "{{ region_code }}"
  env         = "{{ env }}"
  cidr        = "{{ cidr }}"
  hub_cidr    = "{{ hub_cidr }}"
  er_asn      = {{ er_asn }}
  rg_name     = "{{ rg_name }}"
}

# ── Resource Group ────────────────────────────────────────────
resource "azurerm_resource_group" "network" {
  name     = local.rg_name
  location = local.location
  tags = {
    ManagedBy   = "Terraform"
    Environment = local.env
    Org         = local.org_name
  }
}

# ── vWAN + vHub ───────────────────────────────────────────────
module "vwan" {
  source  = "../../../../modules/azure-vwan-hub"
  version = "~> 2.0"

  org_name          = local.org_name
  resource_group_id = azurerm_resource_group.network.id
  location          = local.location
  env               = local.env
  hub_cidr          = local.hub_cidr
  er_asn            = local.er_asn

  # Azure Firewall Premium — routing intent
  enable_azure_firewall       = true
  firewall_sku_tier           = "Premium"
  enable_routing_intent       = true
  routing_intent_destinations = ["Internet", "PrivateTraffic"]
}

# ── ExpressRoute Gateway ──────────────────────────────────────
module "er_gateway" {
  source = "../../../../modules/azure-er-gateway"

  resource_group_id = azurerm_resource_group.network.id
  location          = local.location
  virtual_hub_id    = module.vwan.virtual_hub_id
  er_sku            = "ErGw3AZ"
}

# ── Azure Firewall Policy (Premium) ──────────────────────────
resource "azurerm_firewall_policy" "premium" {
  name                = "${local.org_name}-fwpol-${local.region_code}"
  resource_group_name = azurerm_resource_group.network.name
  location            = local.location
  sku                 = "Premium"

  threat_intelligence_mode = "Alert"
  intrusion_detection {
    mode = "Alert"
  }
}

# ── Spoke VNet peering to vHub ────────────────────────────────
# (Spoke VNets connect via module.vwan virtual_hub_connection)

# ── Outputs ───────────────────────────────────────────────────
output "vwan_id" {
  value       = module.vwan.vwan_id
  description = "Virtual WAN ID"
}

output "virtual_hub_id" {
  value       = module.vwan.virtual_hub_id
  description = "Virtual Hub ID"
}

output "er_gateway_id" {
  value       = module.er_gateway.gateway_id
  description = "ExpressRoute Gateway ID"
}

output "firewall_private_ip" {
  value       = module.vwan.firewall_private_ip
  description = "Azure Firewall Premium private IP"
}

output "firewall_policy_id" {
  value       = azurerm_firewall_policy.premium.id
  description = "Azure Firewall Policy (Premium) ID"
}

output "resource_group_id" {
  value       = azurerm_resource_group.network.id
  description = "Network resource group ID"
}
