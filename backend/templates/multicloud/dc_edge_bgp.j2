{# ═══════════════════════════════════════════════════════════
   IOS-XR BGP Config Template — DC Edge (Multicloud)
   Template: dc_edge_bgp.j2
   Variables:
     hostname          - device hostname (e.g., DC-EAST-EDGE-01)
     site              - DC site label (DC-EAST | DC-WEST)
     location          - IAD | SEA
     local_as          - enterprise BGP AS (e.g., 65000)
     router_id         - loopback IP
     mgmt_cidr         - DC management aggregate (e.g., 10.10.0.0/16)
     bgp_cloud_peers   - list of peer dicts (see ansible_dc_vars.yml.j2)
     prefix_sets       - dict cloud → list of CIDRs
     dc_aggregate_prefixes - list of DC aggregate CIDRs
═══════════════════════════════════════════════════════════ #}
! ═══════════════════════════════════════════════════════════
! Device   : {{ hostname }}
! Role     : DC Edge BGP — Multicloud Connectivity
! Site     : {{ site }} ({{ location }})
! OS       : Cisco IOS-XR
! Local AS : {{ local_as }}
! Generated by NetDesign AI
! ═══════════════════════════════════════════════════════════
!
hostname {{ hostname }}
!
! ── MANAGEMENT ──────────────────────────────────────────────
domain name netdesign.local
!
! ── PREFIX SETS ─────────────────────────────────────────────
{% for cloud, prefixes in prefix_sets.items() %}
prefix-set PERMIT-{{ cloud | upper }}-PREFIXES
{% for prefix in prefixes %}
  {{ prefix }}{{ "," if not loop.last else "" }}
{% endfor %}
end-set
!
{% endfor %}
prefix-set DC-AGGREGATE-PREFIXES
{% for pfx in dc_aggregate_prefixes %}
  {{ pfx }}{{ "," if not loop.last else "" }}
{% endfor %}
end-set
!
! ── ROUTE POLICIES ──────────────────────────────────────────
{% for cloud in prefix_sets.keys() %}
route-policy PERMIT-{{ cloud | upper }}-PREFIXES-IN
  if destination in PERMIT-{{ cloud | upper }}-PREFIXES then
    pass
  else
    drop
  endif
end-policy
!
route-policy PERMIT-DC-TO-{{ cloud | upper }}-OUT
  if destination in DC-AGGREGATE-PREFIXES then
    pass
  else
    drop
  endif
end-policy
!
{% endfor %}
! ── BGP ─────────────────────────────────────────────────────
router bgp {{ local_as }}
 bgp router-id {{ router_id }}
 bgp graceful-restart
 bgp log neighbor changes detail
 !
 address-family ipv4 unicast
  network {{ mgmt_cidr | replace('/16','') }} 255.255.0.0
 !
{% for peer in bgp_cloud_peers %}
 !
 ! {{ peer.description }}  — circuit: {{ peer.circuit_type }}
 neighbor {{ peer.peer_ip }}
  remote-as {{ peer.peer_as }}
  description "{{ peer.description }}"
{% if peer.bfd %}
  bfd fast-detect
  bfd minimum-interval 300
  bfd multiplier 3
{% endif %}
  address-family ipv4 unicast
   route-policy {{ peer.route_policy_in }} in
   route-policy {{ peer.route_policy_out }} out
   maximum-prefix 200 90
   soft-reconfiguration inbound always
  !
{% endfor %}
!
end
