{# ═══════════════════════════════════════════════════════════
   Ansible host_vars — dc-edge-bgp role
   Template: ansible_dc_vars.yml.j2
   Variables:
     org_name          - organization name
     bgp_local_as      - enterprise BGP AS
     bgp_router_id     - loopback IP
     bgp_cloud_peers   - list of peer dicts
     prefix_sets       - dict cloud → list of CIDRs
     dc_aggregate_prefixes - list of DC aggregate CIDRs
═══════════════════════════════════════════════════════════ #}
---
# Ansible host_vars — dc-edge-bgp role
# Org     : {{ org_name }}
# Generated by NetDesign AI

bgp_local_as: {{ bgp_local_as }}
bgp_router_id: "{{ bgp_router_id }}"

bgp_cloud_peers:
{% for peer in bgp_cloud_peers %}
  - name: "{{ peer.name }}"
    peer_ip: "{{ peer.peer_ip }}"
    peer_as: {{ peer.peer_as }}
    local_as: {{ peer.local_as }}
    bfd: {{ "true" if peer.bfd else "false" }}
    description: "{{ peer.description }}"
    route_policy_in:  "{{ peer.route_policy_in }}"
    route_policy_out: "{{ peer.route_policy_out }}"
    circuit_type: "{{ peer.circuit_type }}"

{% endfor %}

prefix_sets:
{% for cloud, prefixes in prefix_sets.items() %}
  PERMIT-{{ cloud | upper }}-PREFIXES:
{% for pfx in prefixes %}
    - "{{ pfx }}"
{% endfor %}
{% endfor %}

route_policies:
{% for cloud in prefix_sets.keys() %}
  PERMIT-{{ cloud | upper }}-PREFIXES-IN:
    - match_prefix_set: "PERMIT-{{ cloud | upper }}-PREFIXES"
      action: permit
  PERMIT-DC-TO-{{ cloud | upper }}-OUT:
    - match_prefix_set: "DC-AGGREGATE-PREFIXES"
      action: permit
    - action: deny
{% endfor %}

dc_aggregate_prefixes:
{% for pfx in dc_aggregate_prefixes %}
  - "{{ pfx }}"
{% endfor %}
