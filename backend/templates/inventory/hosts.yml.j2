# ============================================================================
# NetDesign AI — Nornir SimpleInventory (auto-generated from design)
# Org      : {{ org }}
# Use case : {{ use_case }}
# Devices  : {{ hosts | length }}
# Generated by greenfield.build_inventory() — DO NOT hand-edit; regenerate.
# ============================================================================
{% for h in hosts %}
{{ h.name }}:
  hostname: {{ h.mgmt_ip }}
  platform: {{ h.platform }}
  username: {{ username }}
  password: {{ password }}
  port: 22
  groups:
    - {{ h.group }}
  data:
    role: {{ h.role }}
    layer: {{ h.layer }}
    ztp_platform: {{ h.ztp_platform }}
    ansible_network_os: {{ h.ansible_os }}
    loopback_ip: {{ h.loopback_ip }}
    mgmt_gw: {{ h.mgmt_gw }}
{% if h.serial %}    serial: {{ h.serial }}
{% endif %}
{% endfor %}
