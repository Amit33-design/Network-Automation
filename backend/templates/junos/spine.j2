# NetDesign AI — Juniper JunOS DC Spine (BGP Route Reflector)
# Device  : {{ hostname }}
# Role    : Spine — BGP RR, underlay {{ underlay | upper }}, EVPN signaling
# AS      : {{ bgp_asn }} (iBGP, cluster-id = {{ loopback_ip }})
# ============================================================
# Deploy: load replace terminal → paste → commit
# Verify: show bgp summary | show route protocol bgp

version 23.4R1;

system {
    host-name {{ hostname }};
    domain-name netdesignai.local;
    time-zone UTC;
    authentication-order [ password ];
    root-authentication {
        encrypted-password "$6$ChangeMe"; # replace with mkpasswd output
    }
    login {
        user admin {
            uid 2000;
            class super-user;
            authentication {
                encrypted-password "$6$ChangeMe";
            }
        }
    }
    services {
        ssh {
            root-login deny;
            protocol-version v2;
            max-sessions-per-connection 5;
        }
        netconf {
            ssh { port 830; }
        }
    }
    syslog {
        host 10.100.0.200 {
            any info;
            authorization any;
        }
        file messages { any warning; }
        file interactive-commands { interactive-commands any; }
    }
    ntp {
        server 216.239.35.0 prefer;
        server 216.239.35.4;
    }
}

interfaces {
    # ── OOB management ─────────────────────────────────────────────────────
    em0 {
        description OOB-MANAGEMENT;
        unit 0 {
            family inet { address {{ mgmt_ip }}/24; }
        }
    }
    # ── Loopback — router-id ────────────────────────────────────────────────
    lo0 {
        unit 0 {
            description ROUTER-ID;
            family inet { address {{ loopback_ip }}/32 { primary; } }
        }
    }
    # ── P2P downlinks to leaves (100GbE, MTU 9192) ─────────────────────────
    # Spine end = 10.2.{{ index }}.<(leaf_idx-1)*2+1>/31  (odd)
{% for i in range(1, 9) %}
    et-0/0/{{ i - 1 }} {
        description "DOWNLINK-TO-LEAF-{{ '%02d' % i }}";
        mtu 9192;
        unit 0 {
            family inet { address 10.2.{{ index }}.{{ (i - 1) * 2 + 1 }}/31; }
        }
    }
{% endfor %}
}

routing-options {
    router-id {{ loopback_ip }};
    autonomous-system {{ bgp_asn }};
    forwarding-table {
        export ECMP;
        ecmp-fast-reroute;
    }
}

{% if underlay == 'isis' %}
protocols {
    isis {
        interface lo0.0 { passive; level 2 metric 0; }
{% for i in range(1, 9) %}
        interface et-0/0/{{ i - 1 }}.0 {
            point-to-point;
            level 1 disable;
            bfd-liveness-detection {
                minimum-interval 300;
                multiplier 3;
            }
        }
{% endfor %}
        level 2 { authentication-type md5; authentication-key "ChangeMe!"; }
        export ISIS-EXPORT;
    }
{% else %}
protocols {
    ospf {
        area 0.0.0.0 {
            interface lo0.0 { passive; }
{% for i in range(1, 9) %}
            interface et-0/0/{{ i - 1 }}.0 {
                interface-type p2p;
                bfd-liveness-detection {
                    minimum-interval 300;
                    multiplier 3;
                }
            }
{% endfor %}
        }
    }
{% endif %}
    bgp {
        log-updown;
        group LEAFS {
            type internal;
            local-address {{ loopback_ip }};
            cluster {{ loopback_ip }};
            import RR-TO-LEAF;
            export RR-TO-LEAF;
            family inet {
                unicast { add-path { receive; send { path-count 6; } } }
            }
            family evpn { signaling; }
            multipath {
                multiple-as;
            }
            bfd-liveness-detection {
                minimum-interval 300;
                multiplier 3;
            }
{% for i in range(1, 9) %}
            neighbor 10.0.{{ i }}.{{ i }} {
                description "LEAF-{{ '%02d' % i }}-RR-CLIENT";
            }
{% endfor %}
        }
    }
}

policy-options {
    policy-statement ECMP {
        then { load-balance per-packet; }
    }
    policy-statement RR-TO-LEAF {
        term EVPN-ROUTES {
            from family evpn;
            then {
                next-hop unchanged;
                accept;
            }
        }
        term ACCEPT-ALL {
            then accept;
        }
    }
    policy-statement LEAF-TO-RR {
        term LOOPBACKS {
            from {
                route-filter 10.0.0.0/8 orlonger;
            }
            then accept;
        }
        term DENY-REST {
            then reject;
        }
    }
}

# ── SNMP v3 ──────────────────────────────────────────────────────────────────
snmp {
    v3 {
        usm {
            local-engine {
                user ndai-ro {
                    authentication-sha { authentication-password "ChangeMe!"; }
                    privacy-aes128 { privacy-password "ChangeMe!"; }
                }
            }
        }
        vacm {
            security-to-group {
                security-model usm { security-name ndai-ro { group NETDESIGN-RO; } }
            }
            access {
                group NETDESIGN-RO {
                    default-context-prefix {
                        security-model usm { security-level privacy { read-view all; } }
                    }
                }
            }
        }
    }
}
