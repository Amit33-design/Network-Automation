! ============================================================
! NetDesign AI — Cisco IOS-XE  DISTRIBUTION LAYER CONFIG
! Device  : {{ hostname }}
! Layer   : Campus Distribution
! ============================================================

hostname {{ hostname }}

aaa new-model
aaa authentication login default local
aaa authorization exec default local
username admin privilege 15 secret 0 ChangeMe!

service password-encryption
ip domain-name {{ org | lower | replace(' ', '.') }}.local
crypto key generate rsa modulus 2048
ip ssh version 2

line vty 0 15
 transport input ssh
 login authentication default
 exec-timeout 10 0

!-- Loopback
interface Loopback0
 ip address {{ loopback_ip }} 255.255.255.255
 description Router-ID / OSPF RID

!-- Management VLAN SVI
interface Vlan99
 ip address {{ mgmt_ip }} {{ mgmt_mask }}
 no shutdown
 description MANAGEMENT

!-- User VLANs SVIs
{% for vlan in vlans %}
interface Vlan{{ vlan.id }}
 ip address {{ vlan.get('gw', '0.0.0.0') }} 255.255.255.0
 ip helper-address 10.0.0.10
 no shutdown
 description {{ vlan.name }}
{% endfor %}

!-- Uplinks to Core (routed or L2 trunk)
interface GigabitEthernet1/0/1
 description UPLINK-CORE-01
 no switchport
 ip address 10.10.{{ index }}.1 255.255.255.252
 no shutdown

interface GigabitEthernet1/0/2
 description UPLINK-CORE-02
 no switchport
 ip address 10.10.{{ index }}.5 255.255.255.252
 no shutdown

!-- Downlinks to Access (trunk)
{% for i in range(3, 11) %}
interface GigabitEthernet1/0/{{ i }}
 description DOWNLINK-ACCESS-{{ i - 2 }}
 switchport trunk encapsulation dot1q
 switchport mode trunk
 switchport trunk allowed vlan all
 spanning-tree portfast trunk
 no shutdown
{% endfor %}

!-- Routing — OSPF
{% if 'ospf' in protocols %}
router ospf 1
 router-id {{ loopback_ip }}
 passive-interface default
 no passive-interface GigabitEthernet1/0/1
 no passive-interface GigabitEthernet1/0/2
 network {{ loopback_ip }} 0.0.0.0 area 0
 network 10.10.{{ index }}.0 0.0.0.3 area 0
 network 10.10.{{ index }}.4 0.0.0.3 area 0
 auto-cost reference-bandwidth 10000
{% endif %}

!-- HSRP (active/standby per VLAN)
{% for vlan in vlans %}
interface Vlan{{ vlan.id }}
 standby version 2
 standby {{ vlan.id }} ip {{ vlan.get('hsrp_vip', '0.0.0.1') }}
 standby {{ vlan.id }} priority {% if index == 1 %}110{% else %}100{% endif %}
 standby {{ vlan.id }} preempt
{% endfor %}

!-- STP root
spanning-tree mode rapid-pvst
spanning-tree extend system-id
{% if index == 1 %}
spanning-tree vlan 1-4094 priority 4096
{% else %}
spanning-tree vlan 1-4094 priority 8192
{% endif %}

ntp server 10.0.0.1
logging buffered 16384
logging host 10.100.0.100

end
