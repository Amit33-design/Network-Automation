! ============================================================
! NetDesign AI — Cisco IOS-XE  ACCESS LAYER CONFIG
! Device  : {{ hostname }}
! Layer   : Campus Access
! Generated by NetDesign AI
! ============================================================

hostname {{ hostname }}

!-- Local AAA (override with RADIUS/TACACS in production)
aaa new-model
aaa authentication login default local
aaa authorization exec default local

username admin privilege 15 secret 0 ChangeMe!

!-- Management
interface Vlan1
 no ip address
 shutdown

interface Loopback0
 ip address {{ loopback_ip }} 255.255.255.255
 description Management Loopback

ip domain-name {{ org | lower | replace(' ', '.') }}.local
crypto key generate rsa modulus 2048
ip ssh version 2
service password-encryption

!-- VTY
line vty 0 15
 transport input ssh
 login authentication default
 exec-timeout 10 0

!-- VLANs
{% for vlan in vlans %}
vlan {{ vlan.id }}
 name {{ vlan.name }}
{% endfor %}
{% if not vlans %}
vlan 10
 name DATA
vlan 20
 name VOICE
vlan 99
 name MGMT
{% endif %}

!-- Uplink to Distribution (trunk)
interface GigabitEthernet1/0/1
 description UPLINK-TO-DIST
 switchport mode trunk
 switchport trunk allowed vlan all
 spanning-tree portfast trunk
 no shutdown

!-- Access ports
{% for i in range(2, 10) %}
interface GigabitEthernet1/0/{{ i }}
 description ACCESS-PORT-{{ i }}
 switchport mode access
 switchport access vlan 10
 switchport voice vlan {{ voice_vlan }}
 spanning-tree portfast
 spanning-tree bpduguard enable
{% if dot1x_enabled %}
 authentication host-mode multi-auth
 authentication order dot1x mab
 authentication priority dot1x mab
 dot1x pae authenticator
 mab
{% endif %}
 ip dhcp snooping limit rate 15
 no shutdown
{% endfor %}

!-- DHCP Snooping
ip dhcp snooping
ip dhcp snooping vlan 10,20,99
no ip dhcp snooping information option

!-- Dynamic ARP Inspection
{% if dai_enabled %}
ip arp inspection vlan 10,20,99
ip arp inspection validate src-mac dst-mac ip
{% endif %}

!-- STP
spanning-tree mode rapid-pvst
spanning-tree extend system-id

!-- QoS — mark voice
mls qos
class-map match-any VOICE-RTP
 match ip dscp ef
class-map match-any VOICE-SIGNALING
 match ip dscp cs3

policy-map ACCESS-MARKING
 class VOICE-RTP
  set dscp ef
 class VOICE-SIGNALING
  set dscp cs3

!-- NTP + Logging
ntp server 10.0.0.1
logging buffered 16384
logging host 10.100.0.100

end
