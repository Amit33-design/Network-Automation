# NetDesign AI — Backend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# API security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
API_SECRET_KEY=change-me-generate-a-real-secret

# Default device credentials (overridden per-host in inventory)
DEFAULT_DEVICE_USERNAME=admin
DEFAULT_DEVICE_PASSWORD=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Nornir worker threads
NORNIR_WORKERS=10

# Backup directory for running-config snapshots
BACKUP_DIR=/tmp/netdesign_backups

# CORS — set to your frontend URL in production
CORS_ORIGINS=*
