! ============================================================
! NetDesign AI — Arista EOS DAY 0 ZTP BOOTSTRAP CONFIG
! Device  : {{ hostname }}
! Serial  : {{ serial }}
! Role    : {{ role }}
! Generated by NetDesign AI ZTP Server
! ============================================================

hostname {{ hostname }}

!-- Local users
username admin privilege 15 role network-admin secret sha512 $6$ChangeMe!
username netdesign privilege 15 role network-admin secret sha512 $6$NetDesignZTP1!

!-- Management interface
interface Management1
   description MGMT-ZTP
   ip address {{ mgmt_ip }}/24
   no shutdown
{% if mgmt_gw %}

!-- Default route for management
ip route 0.0.0.0/0 {{ mgmt_gw }}
{% endif %}

!-- Loopback
interface Loopback0
   description ROUTER-ID
   ip address {{ loopback_ip }}/32
   no shutdown

!-- SSH
management ssh
   idle-timeout 10
   authentication mode password
   no shutdown

!-- NTP
ntp server 10.100.0.1 prefer

!-- Syslog
logging host 10.100.0.100 514

!-- LLDP
lldp run

!-- Disable ZTP after first boot
event-handler DISABLE-ZTP
   trigger on-boot
   action bash touch /mnt/flash/zerotouch-config
   delay 2

!-- Banner
banner login
*** NetDesign AI EOS — ZTP Bootstrap Complete ***
*** {{ hostname }} | {{ role }} ***
EOF

end
