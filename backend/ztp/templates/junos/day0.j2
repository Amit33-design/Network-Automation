# ============================================================
# NetDesign AI — Junos DAY 0 ZTP BOOTSTRAP CONFIG
# Device  : {{ hostname }}
# Serial  : {{ serial }}
# Role    : {{ role }}
# Generated by NetDesign AI ZTP Server
# ============================================================

system {
    host-name {{ hostname }};
    root-authentication {
        encrypted-password "{{ admin_password }}";
    }
    login {
        user admin {
            uid 2000;
            class super-user;
            authentication {
                encrypted-password "{{ admin_password }}";
            }
        }
        user netdesign {
            uid 2001;
            class super-user;
            authentication {
                encrypted-password "{{ netdesign_password }}";
            }
        }
    }
    services {
        ssh {
            root-login deny;
            protocol-version v2;
        }
        netconf {
            ssh;
        }
    }
    syslog {
        host {{ syslog_server }} {
            any notice;
        }
        file messages {
            any notice;
        }
    }
    ntp {
        server {{ ntp_server }};
    }
}

interfaces {
    {% if 'MX' in role|upper or 'ROUTER' in role|upper %}
    fxp0 {
    {% else %}
    em0 {
    {% endif %}
        unit 0 {
            description "MGMT-ZTP";
            family inet {
                address {{ mgmt_ip }}/24;
            }
        }
    }
    lo0 {
        unit 0 {
            description "ROUTER-ID";
            family inet {
                address {{ loopback_ip }}/32;
            }
        }
    }
}

{% if mgmt_gw %}
routing-options {
    static {
        route 0.0.0.0/0 next-hop {{ mgmt_gw }};
    }
}
{% endif %}
