! ============================================================
! NetDesign AI — NX-OS DAY 0 POAP BOOTSTRAP CONFIG
! Device  : {{ hostname }}
! Serial  : {{ serial }}
! Role    : {{ role }}
! Generated by NetDesign AI ZTP/POAP Server
! ============================================================

hostname {{ hostname }}

!-- Enable features needed for day-0
feature lldp
feature ssh

!-- Disable telnet
no feature telnet

!-- Local admin (CHANGE BEFORE PRODUCTION)
username admin password ChangeMe! role network-admin
username netdesign password NetDesignZTP1! role network-admin

!-- Management VRF
vrf context management
  ip route 0.0.0.0/0 {{ mgmt_gw if mgmt_gw else '10.100.0.1' }}

!-- Management interface
interface mgmt0
  description MGMT-ZTP-POAP
  vrf member management
  ip address {{ mgmt_ip }}/24
  no shutdown

!-- Loopback
interface loopback0
  description ROUTER-ID
  ip address {{ loopback_ip }}/32
  no shutdown

!-- NTP
ntp server {{ '10.100.0.1' }} use-vrf management prefer

!-- Syslog
logging server {{ '10.100.0.100' }} 6 use-vrf management

!-- SSH keys
no ip domain-lookup
ip domain-name {{ hostname | lower }}.ztp.local

!-- Banner
banner motd ^
*** NetDesign AI NX-OS — ZTP/POAP Bootstrap Complete ***
*** {{ hostname }} | {{ role }} ***
^

end
