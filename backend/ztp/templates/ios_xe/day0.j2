! ============================================================
! NetDesign AI — IOS-XE DAY 0 ZTP BOOTSTRAP CONFIG
! Device  : {{ hostname }}
! Serial  : {{ serial }}
! Role    : {{ role }}
! Generated by NetDesign AI ZTP Server
! ============================================================
!
hostname {{ hostname }}
!
! --- Basic security hardening
no service pad
service tcp-keepalives-in
service tcp-keepalives-out
service password-encryption
service timestamps log datetime msec localtime show-timezone year
service timestamps debug datetime msec localtime show-timezone year
!
! --- AAA
aaa new-model
aaa authentication login default local
aaa authorization exec default local if-authenticated
!
! --- Local admin (CHANGE BEFORE PRODUCTION)
username admin privilege 15 algorithm-type sha256 secret ChangeMe!
username netdesign privilege 15 algorithm-type sha256 secret NetDesignZTP1!
!
! --- Disable unsafe services
no ip http server
no ip http secure-server
no ip bootp server
no service dhcp
no ip source-route
no ip finger
no service finger
no cdp run
!
! --- SSH
ip domain-name {{ hostname | lower }}.ztp.local
crypto key generate rsa modulus 4096
ip ssh version 2
ip ssh time-out 60
ip ssh authentication-retries 3
!
! --- Management interface
interface GigabitEthernet0
 description MGMT-ZTP
 ip address {{ mgmt_ip }} {{ mgmt_mask }}
 no shutdown
!
{% if mgmt_gw %}
ip route 0.0.0.0 0.0.0.0 {{ mgmt_gw }}
{% endif %}
!
! --- Loopback
interface Loopback0
 description ROUTER-ID
 ip address {{ loopback_ip }} 255.255.255.255
 no shutdown
!
! --- VTY
line vty 0 15
 transport input ssh
 exec-timeout 10 0
 login authentication default
!
line con 0
 exec-timeout 5 0
 logging synchronous
!
! --- NTP (will be updated by full config)
ntp server 10.100.0.1 prefer
!
! --- Syslog
logging host 10.100.0.100
logging trap informational
!
! --- Banner
banner login ^
*** NetDesign AI — ZTP Bootstrap Complete ***
*** Hostname: {{ hostname }} | Role: {{ role }} ***
*** Full config deployment pending ***
^
!
end
