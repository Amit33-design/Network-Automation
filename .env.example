# NetDesign AI — Environment Configuration
# Copy this file to .env and fill in all values before running docker-compose up.
# NEVER commit .env to version control — it contains secrets.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password_here

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with:  python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_256bit_random_secret_here

# Admin account for POST /api/auth/token (Phase 2 replaces with user table)
ADMIN_USER=admin
ADMIN_PASS=change_me_admin_password_here

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
VAULT_TOKEN=change_me_vault_root_token_here

# ── CORS — comma-separated list of allowed origins (NO wildcards in prod) ─────
CORS_ORIGINS=http://localhost:8080,https://yourdomain.com

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_grafana_password_here

# ── API behaviour ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
NORNIR_WORKERS=10

# ── Device credentials (dev fallback when Vault is not configured) ────────────
DEVICE_DEFAULT_USER=admin
DEVICE_DEFAULT_PASS=

# ── Telemetry paths ───────────────────────────────────────────────────────────
# AUDIT_LOG_PATH=/app/backups/audit.jsonl   # already set in docker-compose
