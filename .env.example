# NetDesign AI — Environment Configuration
# Copy this file to .env and fill in all values before running docker-compose up.
# NEVER commit .env to version control — it contains secrets.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password_here

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with:  python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_256bit_random_secret_here

# Admin account for POST /api/auth/token (Phase 2 replaces with user table)
ADMIN_USER=admin
ADMIN_PASS=change_me_admin_password_here

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
VAULT_TOKEN=change_me_vault_root_token_here

# ── CORS — comma-separated list of allowed origins (NO wildcards in prod) ─────
CORS_ORIGINS=http://localhost:8080,https://yourdomain.com

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_grafana_password_here

# ── API behaviour ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
NORNIR_WORKERS=10

# ── Device credentials (dev fallback when Vault is not configured) ────────────
DEVICE_DEFAULT_USER=admin
DEVICE_DEFAULT_PASS=

# ── Telemetry paths ───────────────────────────────────────────────────────────
# AUDIT_LOG_PATH=/app/backups/audit.jsonl   # already set in docker-compose

# ── License ───────────────────────────────────────────────────────────────────
# Obtain a license key from https://netdesign.ai/activate
# Leave blank to run in Community (free) tier — no deploy features.
LICENSE_KEY=

# ════════════════════════════════════════════════════════════════════════
# SaaS STACK — v2.0 (leave blank for local Docker-only mode)
# ════════════════════════════════════════════════════════════════════════

# ── Clerk — auth + paywall gate (app.clerk.com) ───────────────────────
CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>

# ── Stripe — payments + licensing (dashboard.stripe.com) ─────────────
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxx
STRIPE_BILLING_PORTAL_URL=https://billing.stripe.com/p/login/netdesignai
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxx        # Pro $50/mo
STRIPE_PRICE_TEAM=price_xxxxxxxxxxxxxxxxxxxxxx         # Team 10-seat $400/yr
STRIPE_PRICE_DEPT=price_xxxxxxxxxxxxxxxxxxxxxx         # Dept 50-seat $1,500/yr

# ── Supabase — cloud DB + realtime (supabase.com) ────────────────────
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxx
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Upstash Redis — rate limiting + license cache (upstash.com) ──────
UPSTASH_REDIS_REST_URL=https://xxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxx
FREE_CONFIG_GEN_PER_HR=10
API_REQ_PER_MIN=120

# ── Pinecone — vector DB for design similarity (pinecone.io) ─────────
# Create index: dimension=1536, metric=cosine
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX=netdesign-designs
PINECONE_HOST=https://netdesign-designs-xxx.svc.pinecone.io

# ── OpenAI — embeddings for Pinecone (platform.openai.com) ───────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend — transactional email (resend.com) ─────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=NetDesign AI <noreply@netdesignai.com>

# ── Sentry — error tracking (sentry.io) ───────────────────────────────
SENTRY_DSN=https://xxxxxxxxxxxxxxxx@oxxxxxxxxx.ingest.sentry.io/xxxxxxx
APP_ENV=production
APP_VERSION=2.4.0

# ── PostHog — product analytics (app.posthog.com) ────────────────────
POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Docker self-hosted license key ────────────────────────────────────
NETDESIGN_LICENSE_KEY=NDA-XXXX-XXXX-XXXX
