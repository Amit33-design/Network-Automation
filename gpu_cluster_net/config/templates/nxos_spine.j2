! ============================================================
! Spine: {{ spine.name }}  |  ASN: {{ spine.asn }}
! Generated by gpu-cluster-net — DO NOT EDIT MANUALLY
! ============================================================

feature bgp
feature ospf
feature bfd
feature nv overlay
feature vn-segment-vlan-based
nv overlay evpn

! --- Routing ---
ip forward-protocol nd

! --- Loopback (Router-ID / BGP Source) ---
interface loopback0
  description ROUTER-ID
  ip address {{ spine.loopback0 }}
  ip ospf network point-to-point
  ip router ospf UNDERLAY area 0.0.0.0
  no shutdown

! --- OSPF Underlay ---
router ospf UNDERLAY
  router-id {{ spine.loopback_ip() }}
  bfd

! --- BGP EVPN Route Reflector ---
router bgp {{ spine.asn }}
  router-id {{ spine.loopback_ip() }}
  log-neighbor-changes
  address-family ipv4 unicast
    maximum-paths ibgp 64
    maximum-paths 64
  address-family l2vpn evpn
    retain route-target all
{% for leaf in leaves %}
  neighbor {{ leaf.loopback_ip() }}
    remote-as {{ leaf.asn }}
    description {{ leaf.name }}-EVPN
    update-source loopback0
    ebgp-multihop 3
    bfd
    address-family ipv4 unicast
      send-community extended
      route-map NEXT-HOP-UNCHANGED out
    address-family l2vpn evpn
      send-community extended
      route-reflector-client
{% endfor %}

! --- Route Map: preserve VTEP next-hop ---
route-map NEXT-HOP-UNCHANGED permit 10
  set ip next-hop unchanged

! --- Fabric Uplink Interfaces ---
{% for iface in spine.uplink_interfaces %}
interface {{ iface.name }}
  description {{ iface.description if iface.description else 'FABRIC-UPLINK' }}
  no switchport
  mtu {{ fabric.rocev2.mtu }}
  ip address {{ iface.name }}
  ip ospf network point-to-point
  ip ospf bfd
  ip router ospf UNDERLAY area 0.0.0.0
  no shutdown
{% endfor %}

! --- NTP ---
{% for ntp in fabric.ntp_servers %}
ntp server {{ ntp }} use-vrf management prefer
{% endfor %}
