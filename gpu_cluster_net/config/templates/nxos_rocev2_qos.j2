! ============================================================
! RoCEv2 Lossless QoS Policy — NX-OS
! PFC Priority: {{ rocev2.pfc_priority }}
! ECN Min: {{ rocev2.ecn_min_threshold_bytes }} bytes
! ECN Max: {{ rocev2.ecn_max_threshold_bytes }} bytes
! Generated by gpu-cluster-net — DO NOT EDIT MANUALLY
! ============================================================

! --- System QoS: Enable PFC and ECN globally ---
system qos
  service-policy type network-qos ROCEV2-NETWORK-QOS
  service-policy type queuing input ROCEV2-QUEUING-IN
  service-policy type queuing output ROCEV2-QUEUING-OUT

! --- DSCP → CoS Mapping (RoCEv2 traffic = DSCP {{ rocev2.dscp_rocev2 }} → PFC priority {{ rocev2.pfc_priority }}) ---
class-map type qos match-all ROCEV2-CLASS
  match dscp {{ rocev2.dscp_rocev2 }}

class-map type qos match-all ROCEV2-CLASS-COS
  match cos {{ rocev2.pfc_priority }}

class-map type network-qos ROCEV2-NQ-CLASS
  match qos-group {{ rocev2.pfc_priority }}

class-map type queuing ROCEV2-Q-CLASS
  match qos-group {{ rocev2.pfc_priority }}

! --- QoS Policy: Classify and mark RoCEv2 ---
policy-map type qos ROCEV2-IN
  class ROCEV2-CLASS
    set qos-group {{ rocev2.pfc_priority }}
  class class-default
    set qos-group 0

! --- Network QoS: PFC + MTU per queue ---
policy-map type network-qos ROCEV2-NETWORK-QOS
  class type network-qos ROCEV2-NQ-CLASS
    pause no-drop
    mtu {{ rocev2.mtu }}
{% if rocev2.dcqcn_enabled %}
    congestion-control random-detect ecn minimum-threshold {{ rocev2.ecn_min_threshold_bytes }} bytes maximum-threshold {{ rocev2.ecn_max_threshold_bytes }} bytes drop-probability {{ rocev2.ecn_probability }} weight 0
{% endif %}
  class type network-qos class-default
    mtu {{ rocev2.mtu }}

! --- Queuing: Strict priority for RoCEv2 queue ---
policy-map type queuing ROCEV2-QUEUING-OUT
  class type queuing ROCEV2-Q-CLASS
    priority level 1
    bandwidth remaining percent 0
  class type queuing class-default
    bandwidth remaining percent 100

policy-map type queuing ROCEV2-QUEUING-IN
  class type queuing ROCEV2-Q-CLASS
    bandwidth percent 40
  class type queuing class-default
    bandwidth percent 60

! --- PFC Watchdog ---
{% if rocev2.pfc_watchdog_enabled %}
priority-flow-control watch-dog-interval {{ rocev2.pfc_watchdog_interval_ms }}
priority-flow-control watch-dog-action drop
{% endif %}
