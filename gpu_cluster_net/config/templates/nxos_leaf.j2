! ============================================================
! Leaf: {{ leaf.name }}  |  ASN: {{ leaf.asn }}
! VTEP: {{ leaf.vtep_ip() }}
! Generated by gpu-cluster-net — DO NOT EDIT MANUALLY
! ============================================================

feature bgp
feature ospf
feature bfd
feature interface-vlan
feature vn-segment-vlan-based
feature nv overlay
nv overlay evpn

! --- VRF ---
vrf context {{ fabric.vxlan.vrf_name }}
  vni {{ fabric.vxlan.l3_vni }}
  rd auto
  address-family ipv4 unicast
    route-target import evpn {{ leaf.asn }}:{{ fabric.vxlan.l3_vni }}
    route-target export evpn {{ leaf.asn }}:{{ fabric.vxlan.l3_vni }}
    route-target import evpn auto
    route-target export evpn auto

! --- VLANs ---
vlan {{ fabric.vxlan.vlan_id }}
  name GPU-CLUSTER
  vn-segment {{ fabric.vxlan.l2_vni }}

vlan {{ fabric.vxlan.vlan_id + 1 }}
  name L3-VNI-{{ fabric.vxlan.vrf_name }}
  vn-segment {{ fabric.vxlan.l3_vni }}

! --- Loopback 0: Router-ID ---
interface loopback0
  description ROUTER-ID
  ip address {{ leaf.loopback0 }}
  ip ospf network point-to-point
  ip router ospf UNDERLAY area 0.0.0.0
  no shutdown

! --- Loopback 1: VTEP Source ---
interface loopback1
  description VTEP-SOURCE
  ip address {{ leaf.vtep_loopback }}
  ip ospf network point-to-point
  ip router ospf UNDERLAY area 0.0.0.0
  no shutdown

! --- OSPF Underlay ---
router ospf UNDERLAY
  router-id {{ leaf.loopback_ip() }}
  bfd

! --- BGP EVPN ---
router bgp {{ leaf.asn }}
  router-id {{ leaf.loopback_ip() }}
  log-neighbor-changes
  address-family ipv4 unicast
    maximum-paths ibgp 64
    maximum-paths 64
  address-family l2vpn evpn
{% for spine in spines %}
  neighbor {{ spine.loopback_ip() }}
    remote-as {{ spine.asn }}
    description {{ spine.name }}-EVPN
    update-source loopback0
    ebgp-multihop 3
    bfd
    address-family ipv4 unicast
      send-community extended
    address-family l2vpn evpn
      send-community extended
{% endfor %}
  vrf {{ fabric.vxlan.vrf_name }}
    address-family ipv4 unicast
      advertise l2vpn evpn
      redistribute hmm route-map FABRIC-RMAP
      maximum-paths ibgp 64

route-map FABRIC-RMAP permit 10

! --- SVI: Anycast Gateway ---
interface Vlan{{ fabric.vxlan.vlan_id }}
  description GPU-CLUSTER-GATEWAY
  no shutdown
  vrf member {{ fabric.vxlan.vrf_name }}
  no ip redirects
  ip address {{ fabric.vxlan.anycast_gw_ip }}
  fabric forwarding mode anycast-gateway
  mtu {{ fabric.rocev2.mtu }}

interface Vlan{{ fabric.vxlan.vlan_id + 1 }}
  description L3VNI-{{ fabric.vxlan.vrf_name }}
  no shutdown
  vrf member {{ fabric.vxlan.vrf_name }}
  ip forward
  mtu {{ fabric.rocev2.mtu }}

! --- NVE (VTEP) Interface ---
interface nve1
  no shutdown
  host-reachability protocol bgp
  source-interface loopback1
  member vni {{ fabric.vxlan.l2_vni }}
    ingress-replication protocol bgp
  member vni {{ fabric.vxlan.l3_vni }} associate-vrf

! --- Fabric Uplinks ---
{% for iface in leaf.uplink_interfaces %}
interface {{ iface.name }}
  description TO-{{ iface.peer_device }}-{{ iface.peer_interface }}
  no switchport
  mtu {{ fabric.rocev2.mtu }}
  ip ospf network point-to-point
  ip ospf bfd
  ip router ospf UNDERLAY area 0.0.0.0
  no shutdown
{% endfor %}

! --- GPU Server Ports (Access / RoCEv2) ---
{% for iface in leaf.gpu_interfaces %}
interface {{ iface.name }}
  description {{ iface.description if iface.description else 'GPU-SERVER' }}
  switchport
  switchport mode access
  switchport access vlan {{ fabric.vxlan.vlan_id }}
  spanning-tree port type edge
  spanning-tree bpduguard enable
  mtu {{ fabric.rocev2.mtu }}
  service-policy type qos input ROCEV2-IN
  no shutdown
{% endfor %}

! --- Fabric Forwarding (Anycast GW MAC) ---
fabric forwarding anycast-gateway-mac {{ fabric.vxlan.anycast_gw_mac }}

! --- NTP ---
{% for ntp in fabric.ntp_servers %}
ntp server {{ ntp }} use-vrf management prefer
{% endfor %}
